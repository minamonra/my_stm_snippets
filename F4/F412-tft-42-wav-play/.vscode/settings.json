{
  "cortex-debug.openocdPath": "openocd",
  "cortex-debug.armToolchainPath": "",
  "files.associations": {
    "*.s": "arm"
  },
  "cortex-debug.variableUseNaturalFormat": false,
  "cSpell.enabled": false,
  // 1. Отключаем автоопределение отступов, чтобы VS Code не сбивал настройки
  "editor.detectIndentation": false,
  // 2. Устанавливаем глобальный размер отступа в 2 пробела
  "editor.tabSize": 2,
  // 3. При нажатии Tab должны вставляться пробелы
  "editor.insertSpaces": true,
  // 4. НАСТРОЙКА ФОРМАТТЕРА ДЛЯ C/C++
  "C_Cpp.formatting": "clangFormat",
  // 5. Настройка стиля самого clang-format
  //"C_Cpp.clang_format_fallbackStyle": "{ BasedOnStyle: Google, IndentWidth: 2, BreakBeforeBraces: Attach, ColumnLimit: 0, AlignConsecutiveMacros: Consecutive }",
  "C_Cpp.clang_format_fallbackStyle": "{ BasedOnStyle: Google, IndentWidth: 2, BreakBeforeBraces: Attach, ColumnLimit: 0, AlignConsecutiveMacros: Consecutive, AlignConsecutiveAssignments: Consecutive, AlignConsecutiveDeclarations: Consecutive, AlignTrailingComments: true }",
  // Автоматически форматировать код при сохранении файла (Ctrl+S)
  "editor.formatOnSave": false,
  // 6. ЖЕСТКИЙ ЗАПРЕТ НА САМОВОЛЬНУЮ ВСТАВКУ И СОРТИРОВКУ ИНКЛУДОВ
  // Полностью запрещаем расширению вставлять #include автоматически
  "C_Cpp.intelliSense.autoAddIncludes": false,
  // Отключаем автоматический импорт заголовков при автодополнении
  "C_Cpp.intelliSense.includeCompletion": "disabled",
  // Запрещаем clang-format перемешивать и сортировать инклуды по алфавиту
  "C_Cpp.clang_format_sortIncludes": false,
  // Настройка подсветки и табов строго для Makefile
  "[makefile]": {
    "editor.insertSpaces": false, // ЗАПРЕЩАЕМ пробелы! Нужны только честные табы
    "editor.tabSize": 4, // Визуальный размер таба равен 4
    "editor.detectIndentation": false // Отключаем автоопределение, держим настройки жестко
  },
  "C_Cpp.errorSquiggles": "enabled",
  "C_Cpp.default.compilerPath": "arm-none-eabi-gcc"
}