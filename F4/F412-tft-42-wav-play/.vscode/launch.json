{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Cortex Debug (DAP-Link)",
      "cwd": "${workspaceFolder}",
      "executable": "${workspaceFolder}/build/main.elf",
      "request": "launch",
      "type": "cortex-debug",
      "runToEntryPoint": "main",
      "servertype": "openocd",
      "configFiles": [
        "interface/cmsis-dap.cfg",
        "target/stm32f4x.cfg"
      ],
      "svdFile": "${workspaceFolder}/.vscode/STM32F412.svd",
      "preLaunchTask": "build"
    }
  ]
}