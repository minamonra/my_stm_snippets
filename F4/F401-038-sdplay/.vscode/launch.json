{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Отладка STM32 (DAPLink)",
            "type": "cortex-debug",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/main.elf",
            "servertype": "openocd",
            "configFiles": [
                "interface/cmsis-dap.cfg",
                "target/stm32f4x.cfg"
            ],
            "device": "STM32F401RCT6",
            "runToEntryPoint": "main",
            "showDevDebugOutput": "none",
            "svdFile": "${workspaceFolder}/.vscode/STM32F401.svd"
        }
    
    ]
}