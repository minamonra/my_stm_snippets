{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "command": "make",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [],
            "detail": "Собрать проект"
        },
        {
            "label": "clean",
            "type": "shell",
            "command": "make",
            "args": ["clean"],
            "detail": "Очистить сборку"
        },
        {
            "label": "flash",
            "type": "shell",
            "command": "openocd",
            "args": [
                "-f", "interface/cmsis-dap.cfg",
                "-f", "target/stm32f4x.cfg",
                "-c", "program build/main.elf verify reset exit"
            ],
            "detail": "Прошить через Mini Debugger"
        },
        {
            "label": "erase",
            "type": "shell",
            "command": "openocd",
            "args": [
                "-f", "interface/cmsis-dap.cfg",
                "-f", "target/stm32f4x.cfg",
                "-c", "init",
                "-c", "reset halt",
                "-c", "flash erase_sector 0 0 last",
                "-c", "exit"
            ],
            "detail": "Стереть чип"
        }
    ]
}